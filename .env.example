# ===== ClickUp =====
# Personal API token (workspace "Auton"). Settings -> Apps -> API Token.
CLICKUP_TOKEN=pk_xxxxxxxx
CLICKUP_TEAM_ID=90132819023
CLICKUP_LIST_ID=901327135553

# Status names (exatamente como na lista)
CU_STATUS_TO_SCHEDULE=a agendar
CU_STATUS_SCHEDULED=agendado
CU_STATUS_PUBLISHED=publicado
CU_STATUS_MONITORING=monitorando

# Custom field IDs (lista Agendamentos & Publicacoes)
CU_FIELD_LEGENDA=91c07244-6ce6-42c7-bea2-ec49dba12fd3
CU_FIELD_FORMATO=24e0f126-589f-400c-a602-0e4abe19b809
CU_FIELD_DATA_PUBLICACAO=d5107244-d044-4bd0-ae5c-c07f8a4f194e
CU_FIELD_CONTA_IG=bb68ffc9-1892-438d-a364-9c7d9b7da352
CU_FIELD_IG_MEDIA_ID=cde1cd79-ecdc-43f7-b29e-7d0f42c2eed1
CU_FIELD_LINK_PUBLICADO=e98e36fe-1d17-48b7-a797-9ae9b1623d0f
CU_FIELD_PRIMEIRO_COMENTARIO=eb164fea-7dc2-48ba-9420-e7002c6c2ec6
CU_FIELD_ERRO_PUBLICACAO=1137de68-9a0a-467e-8848-1d0e59844d5e
CU_FIELD_ID_TASK_MAE=3f37fbaa-93d0-4344-9fe2-f7c2c7320383

# ----- Phase 2: campos adicionais (CFG-01) -----
# UUID do custom field "GHL Post ID" (texto) -- criar no ClickUp: lista 901327135553 > Custom Fields > New field > Text
CU_FIELD_GHL_POST_ID=<uuid-do-campo-ghl-post-id>
# UUID do custom field "Link do post" (texto/URL com URL do zip no MinIO)
CU_FIELD_LINK_DO_POST=<uuid-do-campo-link-do-post>
# UUID do campo "Formato" (ja preenchido abaixo -- nao alterar)
# CU_FIELD_FORMATO ja definido acima: 24e0f126-589f-400c-a602-0e4abe19b809

# ===== GoHighLevel (GHL) =====
GHL_TOKEN=pit-xxxxxxxx
GHL_LOCATION_ID=zEFpdSK1pMIC9d8aY4Lm
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Account id da conta Instagram no Social Planner (auton.app)
# Confirmar via: node -e "import('./src/clients/ghl.js').then(m=>m.ghl.listAccounts()).then(r=>console.log(JSON.stringify(r,null,2)))"
GHL_IG_ACCOUNT_ID=6a3942d5892064b3bd23a223_zEFpdSK1pMIC9d8aY4Lm_17841440215631995

# ----- Phase 2: conta Instagram, usuario GHL e nomes de status (CFG-01) -----
# ID da conta auton.app no Social Planner (deve terminar em _17841440215631995)
GHL_ACCOUNT_ID=<account-id-da-conta-auton.app>
# ID do usuario GHL para createPost (obrigatorio -- sem ele a API retorna 422 userId must be a string)
# Obter via: GET /users/?locationId=<GHL_LOCATION_ID> (requer escopo users.readonly no token)
GHL_USER_ID=<user-id-ghl>
# Nomes EXATOS dos status de deteccao e sucesso (se divergirem dos defaults abaixo, ajustar)
STATUS_A_AGENDAR=a agendar
STATUS_AGENDADO=agendado

# ESCOPOS OBRIGATORIOS no GHL Private Integration Token (alem de social-media-posting.*):
#   - medias.write        (upload de arquivo para media library -- sem ele: 401 token not authorized)
#   - medias.readonly     (leitura de arquivos da media library)
#   - users.readonly      (resolver GHL_USER_ID via GET /users/?locationId=...)

# ===== Server / Webhook =====
PORT=3000
# Segredo compartilhado para validar o webhook do GHL
GHL_WEBHOOK_SECRET=

# ===== Polling (gatilho ClickUp->GHL) =====
# Intervalo de verificacao de novas tasks "a agendar" (cron ou ms)
POLL_INTERVAL_MS=300000
